# Cloudflare Worker URL (from wrangler deploy output)
VITE_WORKER_URL=https://aimprint.<your-subdomain>.workers.dev

# Firebase config (from Firebase Console → Project Settings → Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sync agent (used in sync/.env — NOT committed to git)
# WORKER_URL=https://aimprint.<your-subdomain>.workers.dev
# SYNC_TOKEN=your-sync-token-from-settings
